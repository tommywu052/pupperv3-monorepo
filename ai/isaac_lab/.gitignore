# Generated artifacts — keep the Isaac Lab subtree clean.

# logs / diagrams / videos
*.log
*.png
*.mp4

# exported policies & checkpoints (regenerated by play.py / train.py)
*.onnx
*.pt

# training / eval outputs
videos/
logs/

# python build / cache
__pycache__/
*.egg-info/

# video-pipeline scratch (LibreOffice profile + rendered output)
media/**/.lo_profile/
media/**/out/
